# TRADE-Crypto Configuration Template
# 複製此檔案為 config.yaml 並填入真實值

freqtrade:
  api_url: "http://127.0.0.1:18798"
  username: "freqtrade"
  password: "${FREQTRADE_PASSWORD}"  # 從環境變數讀取

binance:
  base_url: "https://api.binance.com/api/v3"
  # API Key 從 ~/.openclaw/credentials/binance.key 讀取

scanning:
  symbols:
    - "BTCUSDT"
    - "ETHUSDT"
    - "BNBUSDT"
    - "SOLUSDT"
    - "XRPUSDT"
    - "ADAUSDT"
    - "DOGEUSDT"
    - "AVAXUSDT"
    - "DOTUSDT"
    - "LINKUSDT"
  interval: "15m"
  limit: 100

decision:
  max_position_size: 0.05  # 5%
  default_stop_loss: 0.05   # 5%
  default_take_profit: 0.10  # 10%
  
risk:
  max_open_trades: 3
  max_daily_trades: 5
